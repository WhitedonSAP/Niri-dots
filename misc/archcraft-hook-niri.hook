[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = archcraft-niri
Target = niri

[Action]
Description = Modifying Niri Desktop file...
When = PostTransaction
Exec = /usr/bin/sed -i -e 's/Exec=.*/Exec=run-niri/g' /usr/share/wayland-sessions/niri.desktop
